# trajecktory dashboard (dashboard-web) environment.
#
# Copy this file to .env in this same directory and fill in the values:
#   cp .env.example .env
#
# .env is gitignored and must NEVER be committed. Treat these as live secrets:
# rotate them periodically, and revoke immediately if a key is ever exposed.

# Anthropic API key — powers the dashboard's draft endpoints only (cover
# letters, outreach drafts via the SDK). The main /career-ops pipeline runs on
# your Claude Code login and does NOT need this key; leave it blank if you do
# not use the dashboard's draft buttons.
# Create one at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# Obsidian Local REST API (optional) — pushes evaluation notes into your vault.
# The key and port come from the Obsidian "Local REST API" community plugin.
OBSIDIAN_API_KEY=
OBSIDIAN_PORT=27124

# Optional: absolute path to a pandoc binary if it is not on your PATH
# (used for docx / markdown export). Leave unset to use PATH.
# PANDOC_BIN=

# Optional server settings:
# PORT=3333          # dashboard port (default 3333)
# HOST=127.0.0.1     # bind address. Localhost-only by default. Set to 0.0.0.0
#                    # ONLY if you deliberately want other devices on your
#                    # network to reach the dashboard (it has no password).
