  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "adm-zip": "^0.5.18",
    "dotenv": "^17.4.2",
    "js-yaml": "^4.3.0",
    "playwright": "^1.61.1"
  },
  "devDependencies": {
